# AgentBridge AI Studio
AGENTBRIDGE_DB_PATH=./data/agentbridge_ai.db

# Required for LLM-only agent execution
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# WhatsApp Cloud API config; you can also save these from the UI
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_TEST_RECIPIENT_NUMBER=
WHATSAPP_DEFAULT_WORKFLOW_ID=1
WHATSAPP_AUTO_REPLY_ENABLED=true
